FROM golang:1.22.11 AS builder

WORKDIR /src
COPY . .
RUN go mod download
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -o /out/api ./cmd/api

FROM debian:bookworm-slim
RUN apt-get update && apt-get install -y --no-install-recommends ca-certificates poppler-utils && rm -rf /var/lib/apt/lists/*
WORKDIR /app
COPY --from=builder /out/api /app/api
COPY configs/example_nacos_config.json /app/configs/example_nacos_config.json
COPY migrations /app/migrations
ENTRYPOINT ["/app/api"]
