{
  // 最小可运行配置。系统仅保留：
  // 文档上传 -> 文本解析 -> LLM/启发式抽取 -> 确定性规则生成 T+1 候选计划
  "meta": {
    "app_name": "finance-sys",
    "env": "dev",
    "timezone": "Asia/Shanghai",
    "config_version": 2
  },
  "service": {
    "http": {
      "host": "0.0.0.0",
      "port": 18080,
      "api_prefix": "/api/v1",
      "read_timeout_ms": 30000,
      "write_timeout_ms": 30000,
      "idle_timeout_ms": 60000,
      "shutdown_timeout_seconds": 20,
      "max_header_bytes": 1048576,
      "cors": {
        "enabled": true,
        "allow_origins": ["http://localhost:3000"]
      }
    }
  },
  "nacos_client": {
    "poll_interval_seconds": 30,
    "cache_last_good_config": true,
    "cache_dir": "./configs/.cache",
    "write_config_snapshot_to_db": true
  },
  "security": {
    "auth": {
      "enabled": false,
      "static_tokens": ["dev-token"],
      "header_name": "Authorization",
      "token_prefix": "Bearer "
    }
  },
  "logging": {
    "level": "INFO"
  },
  "database": {
    "driver": "mysql",
    "dsn": "expert_trade:change_me@tcp(localhost:3306)/expert_trade?parseTime=true&multiStatements=true&charset=utf8mb4",
    "max_open_conns": 20,
    "max_idle_conns": 10,
    "conn_max_lifetime_minutes": 30,
    "conn_max_idle_time_minutes": 10
  },
  "document": {
    "api_upload_enabled": true,
    "auto_analyze_upload": true,
    "allowed_extensions": [".pdf", ".doc", ".docx", ".txt", ".md", ".csv"],
    "max_file_size_mb": 50,
    "sha256_dedup": true,
    "source_defaults": {
      "source_type": "manual",
      "source_name": "upload",
      "author": "",
      "institution": ""
    },
    "chunking": {
      "enabled": true,
      "target_chars": 1000,
      "overlap_chars": 120
    }
  },
  "llm": {
    "enabled": true,
    "provider": "openai_compatible",
    "endpoint": "http://127.0.0.1:11434/v1/chat/completions",
    "api_key": "",
    "model": "qwen2.5:14b-instruct",
    "timeout_ms": 20000,
    "max_retries": 2
  },
  "rules": {
    "version": "rules-v2",
    "strategy": "TEXT_REFERENCE_PRICE",
    "trade_date_offset_days": 1,
    "max_position_pct": 0.15,
    "default_stop_loss_pct": 0.03,
    "default_take_profit_pct": 0.06,
    "min_confidence": 0.65
  }
}
